# Mindlogic / FactChat API Gateway — https://docs.mindlogic.ai/docs/ssu/gateway/getting-started/overview
FACTCHAT_API_KEY=your-factchat-api-key-here
FACTCHAT_BASE_URL=https://factchat-cloud.mindlogic.ai/v1/gateway
FACTCHAT_MODEL=gemini-3.1-flash-lite-preview
FACTCHAT_TIMEOUT_SECONDS=30

# OpenWeatherMap — https://openweathermap.org/api (무료 플랜으로 충분)
OPENWEATHER_API_KEY=your-openweather-api-key-here
OPENWEATHER_CITY=Seoul          # 데모 시연 도시
OPENWEATHER_LANG=kr

# Domain & mode
AMICONNECT_DOMAIN=senior_care      # senior_care | general
AMICONNECT_PRIVACY_MODE=false       # true → cloud LLM 호출 차단
AMICONNECT_LOCAL_CONFIDENCE_THRESHOLD=0.65

# Audio (sounddevice 입력 인덱스. 비워두면 기본 장치)
AMICONNECT_MIC_INDEX=

# TTS (MeloTTS)
AMICONNECT_TTS_LANGUAGE=KR
AMICONNECT_TTS_SPEAKER=KR
AMICONNECT_TTS_DEVICE=auto
AMICONNECT_TTS_SPEED=1.0
AMICONNECT_TTS_PLAY=true
